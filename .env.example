# ─────────────────────────────────────────────────────────────
# Prox-Recycle scan engine — server-side only. Hybrid pipeline:
#   [1] Groq (vision) describes the photo
#   [2] Microsoft Foundry IQ (text model) grounds + cites the reward
# Leave blank to run in MOCK mode (no keys needed).
# ─────────────────────────────────────────────────────────────

# [1] Groq vision — free key at https://console.groq.com/keys
GROQ_API_KEY="<your-groq-key>"
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# [2] Microsoft Foundry IQ — from the Foundry portal deployment (https://ai.azure.com)
FOUNDRY_ENDPOINT="https://<your-resource>.services.ai.azure.com/models"
FOUNDRY_API_KEY="<your-foundry-api-key>"
FOUNDRY_DEPLOYMENT="Phi-4-mini-instruct"
FOUNDRY_API_VERSION="2024-05-01-preview"

# Backend port (Express)
PORT="8787"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
